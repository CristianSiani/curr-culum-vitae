<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Cristian Siñani · CV Operaciones & Tecnología</title>
    <!-- Fuentes modernas -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #10172b 0%, #1a2335 100%);
            font-family: 'Inter', sans-serif;
            color: #e2e8f0;
            padding: 2rem 1.5rem;
            line-height: 1.5;
            transition: background 0.3s ease;
        }

        /* Modo claro */
        body.light-mode {
            background: linear-gradient(145deg, #eef2f9 0%, #d9e2ef 100%);
            color: #0a1e2f;
        }

        body.light-mode .cv-container {
            background: #ffffff;
            color: #1e293b;
        }

        body.light-mode .sidebar {
            background: #f8fafc;
            border-right-color: #e2e8f0;
        }

        body.light-mode .content {
            background: #ffffff;
        }

        body.light-mode .section-title {
            color: #0f172a;
        }

        body.light-mode .about-text, 
        body.light-mode .job-description {
            color: #334155;
        }

        body.light-mode .date {
            background: #f1f5f9;
            color: #475569;
        }

        body.light-mode .tech-tag {
            background: #eef2ff;
            color: #1e293b;
        }

        body.light-mode .contact-info {
            background: #e2e8f0;
        }

        body.light-mode .contact-info a {
            color: #0f172a;
        }

        body.light-mode .progress-bar {
            background: #e2e8f0;
        }

        body.light-mode footer {
            background: #f1f5f9;
            color: #475569;
        }

        body.light-mode .badge-oper {
            background: #0f172a20;
            color: #0f172a;
        }

        .cv-container {
            max-width: 1200px;
            margin: 0 auto;
            background: #0f172a;
            border-radius: 2rem;
            box-shadow: 0 30px 50px -20px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            transition: background 0.3s;
        }

        /* Cabecera industrial */
        .header {
            background: #020617;
            padding: 2rem 2.5rem;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 1.5rem;
            border-bottom: 3px solid #f59e0b;
        }

        .title-section h1 {
            font-size: 2.6rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, #ffffff, #fbbf24);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .badge-oper {
            display: inline-block;
            background: #f59e0b20;
            backdrop-filter: blur(4px);
            padding: 0.3rem 1rem;
            border-radius: 40px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-top: 0.75rem;
            border: 1px solid #f59e0b80;
            color: #fde68a;
        }

        .contact-info {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            background: #1e293b;
            padding: 0.7rem 1.5rem;
            border-radius: 60px;
        }

        .contact-info a, .contact-info span {
            color: #cbd5e6;
            text-decoration: none;
            font-size: 0.85rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: 0.2s;
        }

        .contact-info a:hover {
            color: #fbbf24;
            transform: translateY(-2px);
        }

        /* Layout principal */
        .cv-main {
            display: grid;
            grid-template-columns: 1fr 2.2fr;
            gap: 0;
        }

        /* SIDEBAR */
        .sidebar {
            background: #111827;
            padding: 2rem 1.8rem;
            border-right: 1px solid #1e293b;
        }

        .profile-icon {
            text-align: center;
            margin-bottom: 2rem;
        }

        .avatar {
            width: 120px;
            height: 120px;
            background: linear-gradient(145deg, #f59e0b, #b45309);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            box-shadow: 0 10px 20px -5px rgba(0,0,0,0.4);
            border: 3px solid #fbbf24;
        }

        .avatar i {
            font-size: 3.5rem;
            color: #020617;
        }

        .section {
            margin-bottom: 2rem;
        }

        .section-title {
            font-weight: 700;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #fbbf24;
            border-left: 4px solid #f59e0b;
            padding-left: 0.9rem;
            margin-bottom: 1.2rem;
        }

        .skill-item {
            margin-bottom: 1rem;
        }

        .skill-name {
            font-weight: 500;
            font-size: 0.85rem;
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
        }

        .progress-bar {
            background: #1e293b;
            height: 6px;
            border-radius: 10px;
            overflow: hidden;
        }

        .progress-fill {
            background: #f59e0b;
            width: 0%;
            height: 100%;
            border-radius: 10px;
        }

        .lang-item {
            display: flex;
            justify-content: space-between;
            font-size: 0.85rem;
            padding: 0.4rem 0;
            border-bottom: 1px dashed #334155;
        }

        .interest-item {
            display: flex;
            align-items: center;
            gap: 0.7rem;
            font-size: 0.85rem;
            padding: 0.4rem 0;
        }

        .interest-item i {
            width: 24px;
            color: #fbbf24;
        }

        /* CONTENIDO PRINCIPAL */
        .content {
            padding: 2rem 2rem;
            background: #0f172a;
        }

        .about-text {
            background: #1e293b;
            padding: 1rem 1.3rem;
            border-radius: 1rem;
            margin-bottom: 2rem;
            border-left: 4px solid #f59e0b;
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .job, .education-item {
            margin-bottom: 1.5rem;
        }

        .job-header, .edu-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            margin-bottom: 0.4rem;
        }

        .job-title, .edu-title {
            font-weight: 700;
            font-size: 1rem;
            color: #fde68a;
        }

        .company, .institute {
            font-weight: 500;
            color: #fbbf24;
            font-size: 0.85rem;
        }

        .date {
            font-size: 0.7rem;
            color: #94a3b8;
            background: #1e293b;
            padding: 0.2rem 0.7rem;
            border-radius: 20px;
        }

        .job-description {
            font-size: 0.85rem;
            color: #cbd5e6;
            margin-top: 0.5rem;
            padding-left: 0.8rem;
            border-left: 2px solid #334155;
        }

        .tech-stack {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin: 8px 0 4px;
        }

        .tech-tag {
            background: #1e293b;
            padding: 0.2rem 0.7rem;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 500;
            color: #fde68a;
        }

        hr {
            margin: 1rem 0;
            border: 0;
            height: 1px;
            background: linear-gradient(to right, #f59e0b40, transparent);
        }

        footer {
            background: #020617;
            text-align: center;
            padding: 1rem;
            font-size: 0.7rem;
            color: #94a3b8;
            border-top: 1px solid #f59e0b20;
        }

        .dark-toggle {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #f59e0b;
            border: none;
            color: #020617;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 1.3rem;
            box-shadow: 0 4px 14px rgba(0,0,0,0.3);
            z-index: 99;
            transition: 0.2s;
            font-weight: bold;
        }

        .dark-toggle:hover {
            transform: scale(1.05);
            background: #fbbf24;
        }

        @media (max-width: 800px) {
            .cv-main {
                grid-template-columns: 1fr;
            }
            .sidebar {
                border-right: 0;
                border-bottom: 1px solid #1e293b;
            }
            .header {
                flex-direction: column;
                text-align: center;
            }
            .contact-info {
                justify-content: center;
            }
            body {
                padding: 1rem;
            }
        }

        i.fa, i.fab, i.fas {
            margin-right: 2px;
        }
    </style>
</head>
